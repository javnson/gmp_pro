      ]
    },
    {
      "name": "Input Current Sensor",
      "requirements": [
        "Input Current Sensitivity",
        "Input Current Bias"
      ]
    },
    {
      "name": "Output Current Sensor",
      "requirements": [
        "Output Current Sensitivity",
