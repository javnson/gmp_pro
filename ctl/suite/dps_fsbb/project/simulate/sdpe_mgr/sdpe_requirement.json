      ]
    },
    {
      "name": "Inductor Current Sensor",
      "requirements": [
        "Inductor Current Sensitivity",
        "Inductor Current Bias"
      ]
    },
    {
      "name": "MOSFET Parameters",
      "requirements": [
        "MOSFET On Resistance",
        "MOSFET Snubber Resistance",
        "MOSFET Snubber Capacitance",
        "Diode Forward Voltage",
        "Diode On Resistance",
        "Switch Inductance"
      ]
    },
    {
      "name": "Protection Parameters",
      "requirements": [
        "Maximum Input Voltage",
        "Minimum Input Voltage",
        "Nominal Input Voltage",
        "Maximum Output Voltage",
        "Minimum Output Voltage",
        "Maximum Output Current",
        "Default Output Voltage",
