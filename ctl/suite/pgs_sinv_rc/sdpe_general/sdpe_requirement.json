{
  "id": "pgs_sinv_rc_common",
  "macro_prefix": "PGS_SINV_RC_COMMON",
  "display_name": "PGS Single-Phase Inverter Common Control",
  "description": "Platform-independent control contract shared by all pgs_sinv_rc projects.",
  "suite": "pgs_sinv_rc",
  "version": "1.0.0",
  "updated_at": "2026-07-15",
  "output_header": "sdpe_pgs_sinv_rc_common_settings.h",
  "hardware": [],
  "feature_macros": [
    {
      "group": "Control Features",
      "macro": "SINV_ENABLE_REPETITIVE_CONTROL",
      "enabled": true,
      "value": "",
      "description": "Enable delayed insertion of the frequency-adaptive repetitive controller."
    },
    {
      "group": "Control Features",
      "macro": "SINV_ENABLE_GRID_VOLTAGE_FEEDFORWARD",
      "enabled": true,
      "value": "",
      "description": "Enable grid-voltage feedforward for closed-current-loop build levels."
    },
    {
      "group": "Runtime",
      "macro": "CIA402_CONFIG_ENABLE_SEQUENCE_SWITCH",
      "enabled": true,
      "value": "",
      "description": "Allow ENABLE_OPERATION to advance through the complete CiA402 startup sequence."
    }
  ],
  "option_macros": [],
  "requirements": [
    {
      "role": "grid_frequency",
      "macro": "CTRL_GRID_FREQUENCY",
      "binding": {
        "float": "50.0"
      },
      "description": "Nominal grid frequency in Hz."
    },
    {
      "role": "pll_kp",
      "macro": "CTRL_PLL_KP",
      "binding": {
        "float": "10.0"
      },
      "description": "SOGI PLL proportional gain."
    },
    {
      "role": "pll_ti",
      "macro": "CTRL_PLL_TI",
      "binding": {
        "float": "0.02"
      },
      "description": "SOGI PLL integral time constant in seconds."
    },
    {
      "role": "pll_lpf",
      "macro": "CTRL_PLL_LPF_FC",
      "binding": {
        "float": "20.0"
      },
      "description": "PLL error-filter cutoff frequency in Hz."
    },
    {
      "role": "pll_epsilon",
      "macro": "CTRL_SPLL_EPSILON",
      "binding": {
        "float": "0.005"
      },
      "description": "PLL frequency-error lock threshold in PU."
    },
    {
      "role": "pq_lpf",
      "macro": "CTRL_PQ_LPF_FC",
      "binding": {
        "float": "200.0"
      },
      "description": "Power measurement low-pass cutoff frequency in Hz."
    },
    {
      "role": "current_limit",
      "macro": "CTRL_CURRENT_LIMIT_PU",
      "binding": {
        "float": "0.9"
      },
      "description": "Peak current command limit in PU."
    },
    {
      "role": "grid_min",
      "macro": "CTRL_GRID_VMIN_PU",
      "binding": {
        "float": "0.1"
      },
      "description": "Minimum voltage magnitude used by the P/Q reference generator."
    },
    {
      "role": "p_slew",
      "macro": "CTRL_P_SLEW_PU_S",
      "binding": {
        "float": "5.0"
      },
      "description": "Active-power command slew limit in PU/s."
    },
    {
      "role": "q_slew",
      "macro": "CTRL_Q_SLEW_PU_S",
      "binding": {
        "float": "5.0"
      },
      "description": "Reactive-power command slew limit in PU/s."
    },
    {
      "role": "current_deadband",
      "macro": "CTRL_CURRENT_DB_PU",
      "binding": {
        "float": "0.01"
      },
      "description": "Current deadband used by PWM dead-time compensation."
    },
    {
      "role": "current_bandwidth",
      "macro": "SINV_CURRENT_LOOP_BANDWIDTH_HZ",
      "binding": {
        "float": "600.0"
      },
      "description": "QPR current-loop crossover target in Hz."
    },
    {
      "role": "fdrc_min_frequency",
      "macro": "CTRL_FDRC_MIN_FREQ",
      "binding": {
        "float": "45.0"
      },
      "description": "Minimum fundamental tracked by FDRC in Hz."
    },
    {
      "role": "fdrc_delay",
      "macro": "SINV_FDRC_ENABLE_DELAY_MS",
      "binding": {
        "number": "300"
      },
      "description": "Settling time before repetitive control starts learning."
    },
    {
      "role": "fdrc_gain",
      "macro": "SINV_FDRC_LEARNING_GAIN",
      "binding": {
        "float": "0.10"
      },
      "description": "Repetitive-control learning gain."
    },
    {
      "role": "fdrc_filter",
      "macro": "SINV_FDRC_Q_FILTER_HZ",
      "binding": {
        "float": "1000.0"
      },
      "description": "FDRC robustness-filter cutoff frequency."
    },
    {
      "role": "fdrc_lead",
      "macro": "SINV_FDRC_LEAD_STEPS",
      "binding": {
        "float": "3.0"
      },
      "description": "Plant-delay compensation in controller samples."
    },
    {
      "role": "fdrc_error",
      "macro": "SINV_FDRC_FREEZE_ERROR_PU",
      "binding": {
