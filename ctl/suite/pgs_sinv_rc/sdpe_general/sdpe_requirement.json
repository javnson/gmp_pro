    {
      "role": "power_ki",
      "macro": "SINV_POWER_LOOP_KI",
      "binding": {
        "float": "8.0"
      },
      "description": "Active-power outer-loop integral gain per second."
    },
    {
      "role": "bus_ref",
      "macro": "SINV_DC_BUS_REF_V",
      "binding": {
        "float": "60.0"
      },
      "description": "BUILD_LEVEL 5 physical DC bus voltage target."
