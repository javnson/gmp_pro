    {
      "role": "outer_limit",
      "macro": "SINV_OUTER_LOOP_POWER_LIMIT_PU",
      "binding": {
        "float": "0.65"
      },
      "description": "Symmetric outer-loop active-power command limit."
    },
    {
      "role": "outer_frequency",
      "macro": "SINV_OUTER_LOOP_FREQUENCY_HZ",
      "binding": {
        "float": "1000.0"
      },
      "description": "Power and DC-bus outer-loop execution frequency."
    },
    {
      "role": "startup_delay",
      "macro": "SINV_CIA402_OPERATION_ENABLE_DELAY_MS",
      "binding": {
        "number": "100"
