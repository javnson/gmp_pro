    {
      "role": "level3_power",
      "macro": "SINV_LEVEL3_ACTIVE_POWER_REF_PU",
      "binding": {
        "float": "0.10"
      },
      "description": "BUILD_LEVEL 3 signed grid active-power command; positive exports power."
    },
    {
      "role": "level3_reactive",
      "macro": "SINV_LEVEL3_REACTIVE_POWER_REF_PU",
      "binding": {
        "float": "0.0"
      },
      "description": "BUILD_LEVEL 3 grid reactive-power command."
    },
    {
      "role": "level4_power",
      "macro": "SINV_LEVEL4_ACTIVE_POWER_REF_PU",
      "binding": {
        "float": "0.15"
      },
      "description": "BUILD_LEVEL 4 measured active-power closed-loop target."
    },
    {
      "role": "power_kp",
      "macro": "SINV_POWER_LOOP_KP",
      "binding": {
        "float": "0.6"
      },
      "description": "Active-power outer-loop proportional gain."
