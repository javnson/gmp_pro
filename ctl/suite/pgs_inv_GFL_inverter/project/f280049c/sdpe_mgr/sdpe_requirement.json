  "code_sections": {
    "after_extern_open": "#include <sdpe_pgs_inv_gfl_common_settings.h>\n\n/* Existing LaunchPad SysConfig resource names assigned to GFL roles. */\n#define PHASE_U_BASE EPWM_J4_PHASE_U_BASE\n#define PHASE_V_BASE EPWM_J4_PHASE_V_BASE\n#define PHASE_W_BASE EPWM_J4_PHASE_W_BASE\n#define PWM_ENABLE_PORT ENABLE_GATE\n#define PWM_RESET_PORT RESET_GATE\n#define INV_VBUS_RESULT_BASE J3_VDC_RESULT_BASE\n#define INV_VBUS J3_VDC\n#define INV_IBUS_RESULT_BASE J7_VDC_RESULT_BASE\n#define INV_IBUS J7_VDC\n#define INV_UA_RESULT_BASE J7_VU_RESULT_BASE\n#define INV_UA J7_VU\n#define INV_UB_RESULT_BASE J7_VV_RESULT_BASE\n#define INV_UB J7_VV\n#define INV_UC_RESULT_BASE J7_VW_RESULT_BASE\n#define INV_UC J7_VW\n#define INV_IA_RESULT_BASE J7_IU_RESULT_BASE\n#define INV_IA J7_IU\n#define INV_IB_RESULT_BASE J7_IV_RESULT_BASE\n#define INV_IB J7_IV\n#define INV_IC_RESULT_BASE J7_IW_RESULT_BASE\n#define INV_IC J7_IW\n#define INV_UU_RESULT_BASE J3_VU_RESULT_BASE\n#define INV_UU J3_VU\n#define INV_UV_RESULT_BASE J3_VV_RESULT_BASE\n#define INV_UV J3_VV\n#define INV_UW_RESULT_BASE J3_VW_RESULT_BASE\n#define INV_UW J3_VW\n#define INV_IU_RESULT_BASE J3_IU_RESULT_BASE\n#define INV_IU J3_IU\n#define INV_IV_RESULT_BASE J3_IV_RESULT_BASE\n#define INV_IV J3_IV\n#define INV_IW_RESULT_BASE J3_IW_RESULT_BASE\n#define INV_IW J3_IW\n#define SYSTEM_LED LED_R\n#define CONTROLLER_LED LED_G",
    "before_footer": "#if (BUILD_LEVEL < 1) || (BUILD_LEVEL > 5)\n#error BUILD_LEVEL_must_be_between_1_and_5\n#endif"
  },
  "feature_macros": [],
  "option_macros": [
    {
      "group": "Commissioning",
      "macro": "BUILD_LEVEL",
      "enabled": true,
      "value": "(1)",
      "options": [
        "(1)",
        "(2)",
        "(3)",
        "(4)",
        "(5)"
      ],
      "description": "Incremental control level; level 5 enables the cascaded P/Q power loop."
    },
    {
      "group": "Sampling",
      "macro": "GFL_CURRENT_SAMPLE_PHASE_MODE",
      "enabled": true,
      "value": "(3)",
      "options": [
        "(2)",
        "(3)"
      ],
      "description": "Number of directly sampled phase currents."
    },
    {
      "group": "Sampling",
      "macro": "GFL_VOLTAGE_SAMPLE_PHASE_MODE",
      "enabled": true,
      "value": "(3)",
      "options": [
        "(2)",
        "(3)"
      ],
      "description": "Number of directly sampled phase voltages."
    }
  ],
  "requirements": [
    {
      "role": "startup_delay",
      "macro": "CTRL_STARTUP_DELAY",
      "binding": {
        "number": "100"
      },
      "description": "Startup delay in milliseconds."
    },
    {
      "role": "controller_frequency",
      "macro": "CONTROLLER_FREQUENCY",
      "binding": {
        "number": "10e3"
      },
      "description": "Current-loop and PWM update frequency in hertz."
    },
    {
      "role": "pwm_compare_max",
      "macro": "CTRL_PWM_CMP_MAX",
      "binding": {
        "number": "6000"
      },
      "description": "Validated F280049C ePWM compare range."
    },
    {
      "role": "pwm_deadband",
      "macro": "CTRL_PWM_DEADBAND_CMP",
      "binding": {
        "number": "100"
      },
      "description": "ePWM dead-band count."
    },
    {
      "role": "system_frequency",
      "macro": "CTRL_SYS_FREQUENCY",
      "binding": {
        "number": "100e6"
      },
      "description": "F280049C system clock in hertz."
    },
    {
      "role": "system_tick_divider",
      "macro": "DSP_C2000_DSP_TIME_DIV",
      "binding": {
        "number": "CTRL_SYS_FREQUENCY / 1000 / CTRL_PWM_CMP_MAX / 2"
      },
      "description": "C2000 millisecond tick divider."
    },
    {
      "role": "adc_voltage_reference",
      "macro": "CTRL_ADC_VOLTAGE_REF",
      "binding": {
        "float": "3.3"
      },
      "description": "ADC reference voltage."
    },
    {
      "role": "dc_bus_voltage_base",
      "macro": "CTRL_DCBUS_VOLTAGE",
      "binding": {
        "float": "80.0"
      },
      "description": "DC-bus per-unit voltage base."
    },
    {
      "role": "phase_voltage_base",
      "macro": "CTRL_VOLTAGE_BASE",
      "binding": {
        "literal": "(CTRL_DCBUS_VOLTAGE / 1.73205081f)"
      },
      "description": "SVPWM phase-voltage base."
    },
    {
      "role": "current_base",
      "macro": "CTRL_CURRENT_BASE",
      "binding": {
        "float": "10.0"
      },
      "description": "Phase-current per-unit base in amperes."
    },
    {
      "role": "grid_filter_inductance",
      "macro": "GFL_GRID_FILTER_INDUCTANCE_H",
      "binding": {
        "literal": "(HARMONIA_3PH_LC_FILTER_INDUCTANCE_H)"
      },
      "description": "Harmonia grid-filter inductance."
    },
    {
      "role": "grid_filter_capacitance",
      "macro": "GFL_GRID_FILTER_CAPACITANCE_F",
      "binding": {
        "literal": "(HARMONIA_3PH_LC_FILTER_CAPACITANCE_F)"
      },
      "description": "Harmonia grid-filter capacitance."
    },
    {
      "role": "grid_current_sensitivity",
      "macro": "CTRL_GRID_CURRENT_SENSITIVITY",
      "binding": {
        "literal": "(HARMONIA_3PH_LC_FILTER_PH_CURRENT_SENSITIVITY_MV_A * 0.001f)"
      },
      "description": "Grid-current sensitivity."
    },
    {
      "role": "grid_current_bias",
      "macro": "CTRL_GRID_CURRENT_BIAS",
      "binding": {
        "literal": "(HARMONIA_3PH_LC_FILTER_PH_CURRENT_ZERO_BIAS_V)"
      },
      "description": "Grid-current bias."
