  "requirements": [
    {
      "role": "startup_delay",
      "macro": "CTRL_STARTUP_DELAY",
      "binding": {"number": "100"},
      "description": "Controller startup delay in milliseconds."
    },
    {
      "role": "controller_frequency",
      "macro": "CONTROLLER_FREQUENCY",
      "binding": {"float": "20e3"},
      "description": "Main motor-control ISR frequency in hertz."
    },
    {
      "role": "pwm_compare_max",
      "macro": "CTRL_PWM_CMP_MAX",
      "binding": {"number": "3000 - 1"},
      "description": "Maximum PWM compare count for 20 kHz center-aligned PWM at 120 MHz."
    },
    {
      "role": "pwm_deadband",
      "macro": "CTRL_PWM_DEADBAND_CMP",
      "binding": {"number": "50"},
      "description": "PWM dead-band count."
    },
    {
      "role": "system_frequency",
      "macro": "CTRL_SYS_FREQUENCY",
      "binding": {"number": "120e6"},
      "description": "F280039C system clock frequency in hertz."
    },
    {
      "role": "system_time_divider",
      "macro": "DSP_C2000_DSP_TIME_DIV",
      "binding": {"number": "CTRL_SYS_FREQUENCY / 1000 / CTRL_PWM_CMP_MAX / 2"},
      "description": "C2000 system tick divider derived from the system clock and PWM period."
    },
    {
      "role": "adc_voltage_reference",
      "macro": "CTRL_ADC_VOLTAGE_REF",
      "binding": {"float": "3.3"},
      "description": "ADC reference voltage used by all sensor conversions."
    },
    {
      "role": "dc_bus_voltage_base",
      "macro": "CTRL_DCBUS_VOLTAGE",
      "binding": {"float": "80.0"},
      "description": "Configured DC-bus voltage base."
    },
    {
      "role": "phase_voltage_base",
      "macro": "CTRL_VOLTAGE_BASE",
      "binding": {"literal": "(CTRL_DCBUS_VOLTAGE / 1.73205081f)"},
      "description": "Phase-voltage per-unit base derived from the DC-bus base."
    },
    {
      "role": "current_base",
      "macro": "CTRL_CURRENT_BASE",
      "binding": {"float": "10.0"},
      "description": "Phase-current per-unit base in amperes."
    },
    {
      "role": "encoder_full_scale",
      "macro": "CTRL_POS_ENC_FS",
      "binding": {"number": "10000"},
      "description": "Encoder counts per mechanical revolution."
    },
    {
      "role": "encoder_bias",
      "macro": "CTRL_POS_ENC_BIAS",
      "binding": {"float": "0.0207000002"},
      "description": "Mechanical encoder position bias in per unit."
    },
    {
      "role": "mechanical_division",
      "macro": "CTRL_MECH_DIV",
      "binding": {"number": "5"},
      "description": "Mechanical speed and position division factor."
    },
    {
      "role": "phase_current_sensitivity",
      "macro": "CTRL_INVERTER_CURRENT_SENSITIVITY",
      "binding": {"literal": "(MY_BOARD_PH_SHUNT_RESISTANCE_OHM * MY_BOARD_PH_CSA_GAIN_V_V)"},
      "description": "Phase-current sensor sensitivity in volts per ampere."
    },
    {
      "role": "phase_current_bias",
      "macro": "CTRL_INVERTER_CURRENT_BIAS",
      "binding": {"literal": "(MY_BOARD_PH_CSA_BIAS_V)"},
      "description": "Phase-current sensor zero-current bias in volts."
    },
    {
      "role": "phase_voltage_sensitivity",
      "macro": "CTRL_INVERTER_VOLTAGE_SENSITIVITY",
      "binding": {"literal": "(MY_BOARD_PH_VOLTAGE_SENSE_GAIN)"},
      "description": "Phase-voltage sensing gain in ADC volts per measured volt."
    },
    {
      "role": "phase_voltage_bias",
      "macro": "CTRL_INVERTER_VOLTAGE_BIAS",
      "binding": {"literal": "(MY_BOARD_PH_VOLTAGE_SENSE_BIAS_V)"},
      "description": "Phase-voltage sensor bias in volts."
    },
    {
      "role": "dc_current_sensitivity",
      "macro": "CTRL_DC_CURRENT_SENSITIVITY",
      "binding": {"literal": "(MY_BOARD_DCBUS_CURRENT_SENSE_GAIN)"},
      "description": "DC-bus current sensing gain. The selected inverter reports SENSOR_NONE for this path."
    },
    {
      "role": "dc_current_bias",
      "macro": "CTRL_DC_CURRENT_BIAS",
      "binding": {"literal": "(MY_BOARD_DCBUS_CURRENT_SENSE_BIAS_V)"},
      "description": "DC-bus current sensor bias."
    },
    {
      "role": "dc_voltage_sensitivity",
      "macro": "CTRL_DC_VOLTAGE_SENSITIVITY",
      "binding": {"literal": "(MY_BOARD_DCBUS_VOLTAGE_SENSE_GAIN)"},
      "description": "DC-bus voltage sensing gain in ADC volts per measured volt."
    },
    {
      "role": "dc_voltage_bias",
      "macro": "CTRL_DC_VOLTAGE_BIAS",
      "binding": {"literal": "(MY_BOARD_DCBUS_VOLTAGE_SENSE_BIAS_V)"},
      "description": "DC-bus voltage sensor bias in volts."
    },
    {
      "role": "pwm_dtc_current_deadband",
      "macro": "MCS_PWM_DEADTIME_COMP_CURRENT_DEADBAND_A",
      "binding": {"float": "0.2"},
      "description": "Minimum absolute phase current in amperes before PWM dead-time compensation selects a current direction. Converted to PU with CTRL_CURRENT_BASE at initialization."
    },
    {
      "role": "pwm_dtc_current_hysteresis",
      "macro": "MCS_PWM_DEADTIME_COMP_CURRENT_HYSTERESIS_A",
      "binding": {"float": "0.05"},
      "description": "Phase-current hysteresis band in amperes used to prevent dead-time compensation direction chatter around zero current."
    },
    {
      "role": "open_loop_frequency",
      "macro": "MCS_OPEN_LOOP_FREQ_HZ",
      "binding": {"float": "20.0"},
      "description": "Electrical frequency command in hertz used by the BUILD_LEVEL 1 V/f path and the BUILD_LEVEL 2 synthetic-angle current-loop path."
    },
    {
      "role": "open_loop_frequency_slope",
      "macro": "MCS_OPEN_LOOP_FREQ_SLOPE_HZ_S",
      "binding": {"float": "20.0"},
      "description": "Maximum electrical-frequency slew rate in hertz per second for the synthetic angle generator."
    },
    {
      "role": "mech_position_kp",
      "macro": "MCS_MECH_POSITION_KP_PU",
      "binding": {"float": "5.0"},
      "description": "Position-loop proportional gain. Input is mechanical position error in PU revolutions and output is speed reference in PU, so the gain is speed_pu/position_pu."
    },
    {
      "role": "mech_position_ki",
      "macro": "MCS_MECH_POSITION_KI_PU_S",
      "binding": {"float": "1.0"},
      "description": "Position-loop integral gain in speed_pu/(position_pu*s). The continuous gain is divided by the mechanical-loop sampling frequency internally."
    },
    {
      "role": "mech_velocity_kp",
      "macro": "MCS_MECH_VELOCITY_KP_PU",
      "binding": {"float": "5.0"},
      "description": "Velocity-loop proportional gain. Input is speed error in PU and output is q-axis current/torque reference in PU, so the gain is current_pu/speed_pu."
    },
    {
      "role": "mech_velocity_ki",
      "macro": "MCS_MECH_VELOCITY_KI_PU_S",
      "binding": {"float": "1.0"},
      "description": "Velocity-loop integral gain in current_pu/(speed_pu*s). The continuous gain is divided by the mechanical-loop sampling frequency internally."
    },
    {
      "role": "mech_speed_limit",
      "macro": "MCS_MECH_SPEED_LIMIT_RPM",
      "binding": {"float": "3000.0"},
      "description": "Absolute mechanical speed-command limit in rpm. It is divided by MOTOR_PARAM_MAX_SPEED to obtain the controller PU limit."
    },
    {
      "role": "mech_speed_slope_limit",
      "macro": "MCS_MECH_SPEED_SLOPE_RPM_S",
      "binding": {"float": "3000.0"},
      "description": "Maximum mechanical speed-command slew rate in rpm/s. The configured value corresponds to 1 PU/s for the selected 3000 rpm motor."
    },
    {
      "role": "mech_current_limit",
      "macro": "MCS_MECH_CURRENT_LIMIT_A",
      "binding": {"float": "3.0"},
      "description": "Absolute q-axis current/torque command limit in amperes. It is divided by CTRL_CURRENT_BASE to obtain the controller PU limit; 3 A corresponds to the previous 0.3 PU setting."
    },
    {
      "role": "encoder_speed_filter_cutoff",
      "macro": "MCS_ENCODER_SPEED_FILTER_FC_HZ",
      "binding": {"float": "20.0"},
      "description": "Cutoff frequency in hertz of the low-pass filter applied to encoder-derived mechanical speed."
    },
    {
      "role": "commissioning_id_reference",
      "macro": "MCS_COMMISSIONING_ID_REF_A",
      "binding": {"float": "1.0"},
      "description": "D-axis current reference in amperes used by BUILD_LEVEL 2 and 3 commissioning. Converted to PU using CTRL_CURRENT_BASE."
    },
    {
      "role": "commissioning_iq_reference",
      "macro": "MCS_COMMISSIONING_IQ_REF_A",
      "binding": {"float": "1.0"},
      "description": "Q-axis current reference in amperes used by BUILD_LEVEL 2 and 3 commissioning. Converted to PU using CTRL_CURRENT_BASE."
    },
    {
      "role": "commissioning_speed_reference",
      "macro": "MCS_COMMISSIONING_SPEED_REF_RPM",
      "binding": {"float": "300.0"},
      "description": "Mechanical speed reference in rpm used by BUILD_LEVEL 4 commissioning. Converted to PU using MOTOR_PARAM_MAX_SPEED."
    },
    {
      "role": "cia402_operation_enable_delay",
      "macro": "MCS_CIA402_OPERATION_ENABLE_DELAY_MS",
      "binding": {"number": "100"},
      "description": "Minimum delay in milliseconds before the CiA402 state machine enters Operation Enabled. The project control tick is expressed in milliseconds."
    },
    {
      "role": "adc_calibrator_cutoff",
      "macro": "MCS_ADC_CALIBRATOR_FC_HZ",
      "binding": {"float": "20.0"},
      "description": "Cutoff frequency in hertz of the second-order low-pass filter used while estimating ADC zero offsets."
    },
    {
      "role": "adc_calibrator_quality_factor",
      "macro": "MCS_ADC_CALIBRATOR_Q",
      "binding": {"float": "0.707"},
      "description": "Quality factor of the ADC calibration low-pass filter; 0.707 gives an approximately Butterworth second-order response."
    },
    {
      "role": "spll_epsilon",
      "macro": "CTRL_SPLL_EPSILON",
      "binding": {"literal": "((float2ctrl(0.005)))"},
      "description": "Legacy loop-convergence epsilon retained for controller compatibility."
    }
  ],
  "requirement_groups": [
    {
      "name": "Controller Timing",
      "requirements": ["startup_delay", "controller_frequency", "pwm_compare_max", "pwm_deadband", "system_frequency", "system_time_divider", "adc_voltage_reference"]
    },
    {
      "name": "Per-unit and Encoder Bases",
      "requirements": ["dc_bus_voltage_base", "phase_voltage_base", "current_base", "encoder_full_scale", "encoder_bias", "mechanical_division"]
    },
    {
      "name": "Phase Sensor Scaling",
      "requirements": ["phase_current_sensitivity", "phase_current_bias", "phase_voltage_sensitivity", "phase_voltage_bias"]
    },
    {
      "name": "DC Bus Sensor Scaling",
      "requirements": ["dc_current_sensitivity", "dc_current_bias", "dc_voltage_sensitivity", "dc_voltage_bias"]
    },
    {
      "name": "PWM Compensation and Open-loop Commissioning",
      "requirements": ["pwm_dtc_current_deadband", "pwm_dtc_current_hysteresis", "open_loop_frequency", "open_loop_frequency_slope"]
    },
    {
      "name": "Mechanical Controller Gains",
      "requirements": ["mech_position_kp", "mech_position_ki", "mech_velocity_kp", "mech_velocity_ki"]
    },
    {
      "name": "Mechanical Limits and Feedback",
      "requirements": ["mech_speed_limit", "mech_speed_slope_limit", "mech_current_limit", "encoder_speed_filter_cutoff"]
    },
    {
      "name": "Incremental Commissioning Commands",
      "requirements": ["commissioning_id_reference", "commissioning_iq_reference", "commissioning_speed_reference"]
