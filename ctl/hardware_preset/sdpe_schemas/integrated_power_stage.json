    {"name":"configuration","c_name":"CONFIGURATION","unit":"","required":true,"value_format":"\"{}\"","description":"Half bridge or three-phase bridge."},
    {"name":"phase_count","c_name":"PHASE_COUNT","unit":"","required":false,"value_format":"({}U)","description":"Number of integrated phases.","default":1},
