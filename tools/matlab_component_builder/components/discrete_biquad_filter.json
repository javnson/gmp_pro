  "execution":{"initialize_code":[],"parameter_update_code":["ctl_biquad_filter_t fresh{};","if (mode == 1) ctl_init_biquad_lpf(&fresh, fs, fc, q); else if (mode == 2) ctl_init_biquad_hpf(&fresh, fs, fc, q); else if (mode == 3) ctl_init_biquad_bpf(&fresh, fs, fc, q); else if (mode == 4) ctl_init_biquad_notch(&fresh, fs, fc, q); else if (mode == 5) ctl_init_biquad_peaking_eq(&fresh, fs, fc, q, gain_db); else if (mode == 6) ctl_init_biquad_lowshelf(&fresh, fs, fc, q, gain_db); else ctl_init_biquad_highshelf(&fresh, fs, fc, q, gain_db);","runtime->pending.a[0]=fresh.a[0]; runtime->pending.a[1]=fresh.a[1];","runtime->pending.b[0]=fresh.b[0]; runtime->pending.b[1]=fresh.b[1]; runtime->pending.b[2]=fresh.b[2];"],"step_code":["output_output = ctrl2float(ctl_step_biquad_filter(&runtime->pending, float2ctrl(input_input)));"],"terminate_code":[]},
