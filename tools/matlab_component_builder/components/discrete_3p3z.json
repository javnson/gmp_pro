  "schema_version":1,"id":"intrinsic.discrete.pole_zero_3p3z","display_name":"GMP 3P3Z Compensator","description":"GMP three-pole three-zero compensator with real and complex-pair designs.","category":["Intrinsic","Discrete","Pole-Zero"],"system_type":"siso","template":"generic_stateful_v1",
