{
  "schema_version": 1,
  "environment_version": "1.3.0",
  "python": {
    "version": "3.12.10",
    "requirements": "requirements-gmp.txt",
    "imports": [
      "PyQt5",
      "PyQt6",
      "PySide6",
      "serial",
      "pyqtgraph",
      "numpy",
      "matplotlib",
      "jinja2",
      "symengine"
    ]
  },
  "applications": [
    {
      "name": "git",
      "version": "2.47.1",
      "url": "https://github.com/git-for-windows/git/releases/download/v2.47.1.windows.1/MinGit-2.47.1-64-bit.zip",
      "destination": "apps/git",
      "strip_single_root": false,
      "executables": ["cmd/git.exe"]
    },
    {
      "name": "cmake",
      "version": "3.31.6",
      "url": "https://github.com/Kitware/CMake/releases/download/v3.31.6/cmake-3.31.6-windows-x86_64.zip",
      "destination": "apps/cmake",
      "strip_single_root": true,
      "executables": ["bin/cmake.exe"]
    },
    {
      "name": "ninja",
      "version": "1.12.1",
      "url": "https://github.com/ninja-build/ninja/releases/download/v1.12.1/ninja-win.zip",
      "destination": "apps/ninja",
      "strip_single_root": false,
      "executables": ["ninja.exe"]
    },
    {
      "name": "doxygen",
      "version": "1.13.2",
      "url": "https://www.doxygen.nl/files/doxygen-1.13.2.windows.x64.bin.zip",
      "destination": "apps/doxygen",
      "strip_single_root": false,
      "executables": ["doxygen.exe"]
    },
    {
      "name": "graphviz",
      "version": "12.2.1",
      "url": "https://gitlab.com/api/v4/projects/4207231/packages/generic/graphviz-releases/12.2.1/windows_10_cmake_Release_Graphviz-12.2.1-win64.zip",
      "destination": "apps/graphviz",
      "strip_single_root": true,
      "executables": ["bin/dot.exe"]
    }
  ],
  "vcpkg": {
    "repository_version": "2026.04.27",
    "repository_url": "https://github.com/microsoft/vcpkg/archive/refs/tags/2026.04.27.zip",
    "triplet": "x64-windows",
    "projects": []
  }
}
