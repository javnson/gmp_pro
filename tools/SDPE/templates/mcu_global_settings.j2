{# 0. Configuration Macros #}
{% macro render_config_macros(ctx) %}
/* --- {{ ctx.display_name }} --- */

{% for macro_key, param in ctx.formatted_params.items() %}
/**
 * @brief {{ param.desc }}
{%- if param.unit %}
 * @unit {{ param.unit }}
{%- endif %}
 */
#ifndef {{ macro_key }}
#define {{ macro_key | ljust(30) }} {{ param.value }}
#endif

{% endfor %}

/* --- Derived System Tick Macros --- */

/**
 * @brief System tick divider for C2000 DSP (Specific to execution timing)
 */
#ifndef DSP_C2000_DSP_TIME_DIV
#define DSP_C2000_DSP_TIME_DIV                 (100000 / (CTRL_PWM_CMP_MAX) / 2)
#endif
{% endmacro %}

