{# ====================================================================== #}
{# Paradigm: Resistor Voltage Divider Sensor                              #}
{# ====================================================================== #}

{# 0. Configuration Macros #}
{% macro render_config_macros(ctx) %}
/* --- {{ ctx.display_name }} ({{ ctx.obj_name }}) Parameters --- */

{% for macro_key, param in ctx.formatted_params.items() %}
/**
 * @brief {{ param.desc }}
{%- if param.unit %}
 * @unit {{ param.unit }}
{%- endif %}
 */
#ifndef {{ ctx.prefix }}_{{ macro_key }}
#define {{ ctx.prefix }}_{{ macro_key | ljust(20) }} {{ param.value }}
#endif

{% endfor %}

/* --- Derived Sensitivity and Bias Macros --- */

/**
 * @brief Calculated hardware sensitivity for ADC scaling
 * @unit V/V
 */
#define {{ ctx.prefix }}_SENSITIVITY         (GMP_SDPE_CALC_VOLTAGE_DIVIDER_SENSITIVITY({{ ctx.prefix }}_R_HIGH_OHM, {{ ctx.prefix }}_R_LOW_OHM, {{ ctx.prefix }}_AMP_GAIN))

/**
 * @brief Hardware bias voltage for ADC offset
 * @unit V
 */
#define {{ ctx.prefix }}_BIAS                (GMP_SDPE_CALC_BIAS({{ ctx.prefix }}_BIAS_V))
{% endmacro %}

{# 1. Declaration #}
{% macro render_decl(ctx) %}
// {{ ctx.display_name }} object declaration
{{ ctx.c_type }} {{ ctx.obj_name }};
{% endmacro %}

{# 2. Initialization #}
{% macro render_init(ctx) %}
    // Initialize {{ ctx.display_name }} (Ref: {{ ctx.adc_vref }}V, {{ ctx.adc_res }}-bit)
    {{ ctx.init_func }}(
        &{{ ctx.obj_name }}, 
{%- if ctx.data_injection == 'init' %}
        (adc_gt*){{ ctx.raw_data_source }},
{%- endif %}
        ctl_gain_calc_generic({{ ctx.adc_vref }}f, {{ ctx.prefix }}_SENSITIVITY, {{ ctx.voltage_base }}f),
        ctl_bias_calc_via_Vref_Vbias({{ ctx.adc_vref }}f, {{ ctx.prefix }}_BIAS),
        {{ ctx.adc_res }}, {{ ctx.adc_iqn }});
{% endmacro %}

{# 3. Input Callback #}
{% macro render_input(ctx) %}
{% if ctx.data_injection == 'step' %}
    {{ ctx.step_func }}(&{{ ctx.obj_name }}, {{ ctx.raw_data_source }});
{% else %}
    {{ ctx.step_func }}(&{{ ctx.obj_name }});
{% endif %}
{% endmacro %}

{# 4. Output Callback #}
{% macro render_output(ctx) %}
{% endmacro %}