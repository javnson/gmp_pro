{
    "paradigm_name": "current_hall",
    "display_name": "Hall-effect Current Sensor",
    "template_file": "current_hall.j2",

    "supported_modes": {
        "single_channel": {
            "c_type": "ptr_adc_channel_t",
            "channel_count": 1,
            "init_func": "ctl_init_ptr_adc_channel",
            "step_func": "ctl_step_ptr_adc_channel"
        },
        "dual_channel": {
            "c_type": "dual_adc_channel_t",
            "channel_count": 2,
            "init_func": "ctl_init_dual_adc_channel",
            "step_func": "ctl_step_dual_adc_channel"
        },
        "tri_channel": {
            "c_type": "tri_ptr_adc_channel_t",
            "channel_count": 3,
            "init_func": "ctl_init_tri_ptr_adc_channel",
            "step_func": "ctl_step_tri_ptr_adc_channel"
        }
    },

    "parameters": [
        {
            "name": "sensitivity_v_a",
            "macro_name": "SENSITIVITY_V_A",
            "value_format": "(({}f))",
            "description": "Sensor sensitivity",
            "unit": "V/A"
        },
        {
            "name": "bias_v",
            "macro_name": "BIAS_V",
            "value_format": "(({}f))",
            "description": "Zero-current output voltage",
            "unit": "V"
        },
        {
            "name": "max_cont_arms",
            "macro_name": "MAX_CONT_ARMS",
            "value_format": "(({}f))",
            "description": "Maximum continuous current",
            "unit": "Arms"
        },
        {
            "name": "max_peak_ap",
            "macro_name": "MAX_PEAK_AP",
            "value_format": "(({}f))",
            "description": "Maximum peak current",
            "unit": "Ap"
        },
        {
            "name": "accuracy_class_pct",
            "macro_name": "ACCURACY_CLASS_PCT",
            "value_format": "(({}f))",
            "description": "Overall accuracy class",
            "unit": "%"
        },
        {
            "name": "chip_part_number",
            "macro_name": "CHIP_PN",
            "value_format": "\"{}\"",
            "description": "Hall sensor chip part number",
            "unit": ""
        }
    ],

    "required_context": [
        {
            "name": "adc_vref",
            "type": "float",
            "description": "ADC reference voltage (V)"
        },
        {
            "name": "adc_res",
            "type": "uint16",
            "description": "ADC resolution in bits"
        },
        {
            "name": "adc_iqn",
            "type": "uint16",
            "default": 24,
            "description": "IQ math format number"
        }
    ]
}