{
    "paradigm_name": "voltage_sensor",
    "display_name": "Isolated Voltage Sensor or Transducer",
    "template_file": "voltage_sensor.j2",

    "supported_modes": {
        "single_channel": {
            "c_type": "ptr_adc_channel_t",
            "channel_count": 1,
            "init_func": "ctl_init_ptr_adc_channel",
            "step_func": "ctl_step_ptr_adc_channel"
        },
        "dual_channel": {
            "c_type": "dual_adc_channel_t",
            "channel_count": 2,
            "init_func": "ctl_init_dual_adc_channel",
            "step_func": "ctl_step_dual_adc_channel"
        },
        "tri_channel": {
            "c_type": "tri_ptr_adc_channel_t",
            "channel_count": 3,
            "init_func": "ctl_init_tri_ptr_adc_channel",
            "step_func": "ctl_step_tri_ptr_adc_channel"
        }
    },

    "parameters": [
        {
            "name": "sensitivity_v_v",
            "macro_name": "SENSITIVITY_V_V",
            "value_format": "(({}f))",
            "description": "Sensor transfer gain (Output Voltage / Input Voltage)",
            "unit": "V/V"
        },
        {
            "name": "bias_v",
            "macro_name": "BIAS_V",
            "value_format": "(({}f))",
            "description": "Zero-voltage output bias",
            "unit": "V"
        },
        {
            "name": "max_voltage_v",
            "macro_name": "MAX_VOLTAGE_V",
            "value_format": "(({}f))",
            "description": "Maximum continuous measurable voltage",
            "unit": "V"
        },
        {
            "name": "accuracy_class_pct",
            "macro_name": "ACCURACY_CLASS_PCT",
            "value_format": "(({}f))",
            "description": "Overall accuracy class",
            "unit": "%"
        },
        {
            "name": "chip_part_number",
            "macro_name": "CHIP_PN",
            "value_format": "\"{}\"",
            "description": "Voltage transducer or isolated amplifier part number",
            "unit": ""
        }
    ],

    "required_context": [
        {
            "name": "adc_vref",
            "type": "float",
            "description": "ADC reference voltage (V)"
        },
        {
            "name": "adc_res",
            "type": "uint16",
            "description": "ADC resolution in bits"
        },
        {
            "name": "adc_iqn",
            "type": "uint16",
            "default": 24,
            "description": "IQ math format number"
        },
        {
            "name": "voltage_base",
            "type": "float",
            "description": "System voltage base for per-unit scaling"
        }
    ]
}