{
    "paradigm_name": "current_shunt",
    "display_name": "Shunt-based Current Sensor with Op-Amp",
    "template_file": "current_shunt.j2",

    "output_path": "hardware_presets/current_sensors",

    "instance_databases": [
        "inst/db_standard_shunts.json",
        "inst/db_my_custom_shunts.json"
    ],

    "supported_modes": {
        "single_channel": {
            "c_type": "adc_channel_t",
            "channel_count": 1,
            "init_func": "ctl_init_adc_channel",
            "step_func": "ctl_step_adc_channel",
            "data_injection": "step"
        },
        "dual_channel": {
            "c_type": "dual_adc_channel_t",
            "channel_count": 2,
            "init_func": "ctl_init_dual_adc_channel",
            "step_func": "ctl_step_dual_adc_channel",
            "data_injection": "step"
        },
        "tri_channel": {
            "c_type": "tri_adc_channel_t",
            "channel_count": 3,
            "init_func": "ctl_init_tri_adc_channel",
            "step_func": "ctl_step_adc_tri_channel",
            "data_injection": "step"
        },
        "single_ptr_channel": {
            "c_type": "ptr_adc_channel_t",
            "channel_count": 1,
            "init_func": "ctl_init_ptr_adc_channel",
            "step_func": "ctl_step_ptr_adc_channel",
            "data_injection": "init"
        },
        "dual_ptr_channel": {
            "c_type": "dual_ptr_adc_channel_t",
            "channel_count": 2,
            "init_func": "ctl_init_dual_ptr_adc_channel",
            "step_func": "ctl_step_dual_ptr_adc_channel",
            "data_injection": "init"
        },
        "tri_ptr_channel": {
            "c_type": "tri_ptr_adc_channel_t",
            "channel_count": 3,
            "init_func": "ctl_init_tri_ptr_adc_channel",
            "step_func": "ctl_step_tri_ptr_adc_channel",
            "data_injection": "init"
        }
    },

    "parameters": [
        {
            "name": "r_shunt_ohm",
            "macro_name": "R_SHUNT_OHM",
            "value_format": "(({}f))",
            "description": "Shunt resistor value",
            "unit": "Ohms"
        },
        {
            "name": "amp_gain",
            "macro_name": "AMP_GAIN",
            "value_format": "(({}f))",
            "description": "Total amplifier gain",
            "unit": "V/V"
        },
        {
            "name": "bias_v",
            "macro_name": "BIAS_V",
            "value_format": "(({}f))",
            "description": "Hardware bias voltage before ADC",
            "unit": "V"
        },
        {
            "name": "max_cont_arms",
            "macro_name": "MAX_CONT_ARMS",
            "value_format": "(({}f))",
            "description": "Maximum continuous current",
            "unit": "Arms"
        },
        {
            "name": "max_peak_ap",
            "macro_name": "MAX_PEAK_AP",
            "value_format": "(({}f))",
            "description": "Maximum peak current",
            "unit": "Ap"
        },
        {
            "name": "accuracy_class_pct",
            "macro_name": "ACCURACY_CLASS_PCT",
            "value_format": "(({}f))",
            "description": "Overall accuracy class",
            "unit": "%"
        },
        {
            "name": "chip_part_number",
            "macro_name": "CHIP_PN",
            "value_format": "\"{}\"",
            "description": "Main amplifier or CSA chip part number",
            "unit": ""
        }
    ],

    "required_context": [
        {
            "name": "adc_vref",
            "type": "float",
            "description": "ADC reference voltage (V)"
        },
        {
            "name": "adc_res",
            "type": "uint16",
            "description": "ADC resolution in bits"
        },
        {
            "name": "adc_iqn",
            "type": "uint16",
            "default": 24,
            "description": "IQ math format number"
        },
        {
            "name": "current_base",
            "type": "float",
            "description": "System current base for per-unit scaling"
        },
        {
            "name": "raw_data_source",
            "type": "string",
            "description": "Array pointer (for ptr modes) OR comma-separated raw values (for step modes)."
        }
    ]
}