{# ====================================================================== #}
{# Paradigm: Three-Phase PWM Modulator (Two-Level)                        #}
{# ====================================================================== #}

{# 0. Configuration Macros #}
{% macro render_config_macros(ctx) %}
/* --- {{ ctx.display_name }} ({{ ctx.obj_name }}) Parameters --- */

{% for macro_key, param in ctx.formatted_params.items() %}
/**
 * @brief {{ param.desc }}
{%- if param.unit %}
 * @unit {{ param.unit }}
{%- endif %}
 */
#define {{ ctx.prefix }}_{{ macro_key | ljust(20) }} {{ param.value }}

{% endfor %}

/* --- Derived Timer Count Macros --- */

/**
 * @brief Full scale PWM counter value (Center-aligned mode assumption)
 * @unit Counts
 */
#define {{ ctx.prefix }}_FULL_SCALE_COUNTS   (GMP_SDPE_CALC_PWM_PERIOD_CENTER_ALIGNED({{ ctx.timer_clock_hz }}f, {{ ctx.prefix }}_PWM_FREQ_HZ))

/**
 * @brief Dead-time compensation value
 * @unit Counts
 */
#define {{ ctx.prefix }}_DEADBAND_COUNTS     (GMP_SDPE_CALC_PWM_DEADTIME_COUNTS({{ ctx.timer_clock_hz }}f, {{ ctx.prefix }}_DEADTIME_NS))
{% endmacro %}

{# 1. Declaration #}
{% macro render_decl(ctx) %}
// {{ ctx.display_name }} object declaration
{{ ctx.c_type }} {{ ctx.obj_name }};
{% endmacro %}

{# 2. Initialization #}
{% macro render_init(ctx) %}
    // Initialize {{ ctx.display_name }} (Clock: {{ ctx.timer_clock_hz }}Hz)
    {{ ctx.init_func }}(
        &{{ ctx.obj_name }},
        (pwm_gt){{ ctx.prefix }}_FULL_SCALE_COUNTS,
        (pwm_gt){{ ctx.prefix }}_DEADBAND_COUNTS,
        (ctl_vector3_t*){{ ctx.current_feedback_ptr }},
        {{ ctx.prefix }}_CURR_DB_PU,
        {{ ctx.prefix }}_CURR_HYS_PU);
{% endmacro %}

{# 3. Input Callback (Empty for actuator) #}
{% macro render_input(ctx) %}
{% endmacro %}

{# 4. Output Callback #}
{% macro render_output(ctx) %}
    // Execute modulation algorithm
    {{ ctx.step_func }}(&{{ ctx.obj_name }});
{% endmacro %}