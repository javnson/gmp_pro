{
  "id": "dps_fsbb_iris_node",
  "display_name": "DPS FSBB on F280039C IRIS Node",
  "suite": "dps_fsbb",
  "output_header": "sdpe_dps_fsbb_iris_bindings.h",
  "hardware": [
    {
      "entity": "iris_f280039c_node"
    },
    {
      "entity": "fsbb_inline_shunt_half_bridge"
    },
    {
      "entity": "lvfb_half_bridge_phase_a"
    }
  ],
  "requirements": [
    {
      "role": "input_voltage_sensor_sensitivity",
      "macro": "CTRL_VIN_VOLTAGE_SENSITIVITY",
      "binding": {
        "export": "fsbb_inline_shunt_half_bridge.voltage_sensor.sensitivity"
      },
      "description": "Voltage sensor sensitivity for FSBB input voltage ADC channel."
    },
    {
      "role": "input_voltage_sensor_bias",
      "macro": "CTRL_VIN_VOLTAGE_BIAS",
      "binding": {
        "export": "fsbb_inline_shunt_half_bridge.voltage_sensor.bias"
      },
      "description": "Voltage sensor bias for FSBB input voltage ADC channel."
    },
    {
      "role": "inductor_current_sensitivity",
      "macro": "CTRL_INDUCTOR_CURRENT_SENSITIVITY",
      "binding": {
        "export": "fsbb_inline_shunt_half_bridge.current_sensor.sensitivity"
      },
      "description": "Current sensor sensitivity for FSBB inductor current ADC channel."
    },
    {
      "role": "inductor_current_bias",
      "macro": "CTRL_INDUCTOR_CURRENT_BIAS",
      "binding": {
        "export": "fsbb_inline_shunt_half_bridge.current_sensor.bias"
      },
      "description": "Current sensor bias for FSBB inductor current ADC channel."
    },
    {
      "role": "output_voltage_sensor_sensitivity",
      "macro": "CTRL_VOUT_VOLTAGE_SENSITIVITY",
      "binding": {
        "export": "lvfb_half_bridge_phase_a.voltage_sensor.sensitivity"
      },
      "description": "Voltage sensor sensitivity for FSBB output voltage ADC channel."
    },
    {
      "role": "output_voltage_sensor_bias",
      "macro": "CTRL_VOUT_VOLTAGE_BIAS",
      "binding": {
        "export": "lvfb_half_bridge_phase_a.voltage_sensor.bias"
      },
      "description": "Voltage sensor bias for FSBB output voltage ADC channel."
    },
    {
      "role": "tmcs1133_b2a_range_for_reference",
      "macro": "CTRL_REFERENCE_CURRENT_RANGE_A",
      "binding": {
        "export": "tmcs1133_b2a.range_a"
      },
      "description": "Direct parameter binding example using scope-style entity.parameter syntax."
    },
    {
      "role": "manual_input_voltage_adc_offset",
      "macro": "CTRL_VIN_ADC_OFFSET_MANUAL",
      "binding": {
        "literal": "(2048U)"
      },
      "description": "Manual binding example for requirement values that are not owned by a hardware entity."
    }
  ],
  "peripheral_bindings": {
    "PHASE_BUCK_BASE": "IRIS_F280039C_EPWM1_BASE",
    "PHASE_BOOST_BASE": "IRIS_F280039C_EPWM2_BASE",
    "FSBB_VIN": "IRIS_F280039C_ADC_CH1",
    "FSBB_VOUT": "IRIS_F280039C_ADC_CH2",
    "FSBB_IL": "IRIS_F280039C_ADC_CH3",
    "FSBB_IOUT": "IRIS_F280039C_ADC_CH4"
  },
  "global_macros": {
    "SDPE_ENABLE_DPS_FSBB_BINDINGS": "1"
  },
  "description": "",
  "version": "0.1.0",
  "updated_at": "2026-07-09",
  "feature_macros": [
    {
      "macro": "_USE_DEBUG_DISCRETE_PID",
      "enabled": true,
      "value": "",
      "description": "Enable Discrete PID controller anti-saturation algorithm"
    },
    {
      "macro": "SPECIFY_ENABLE_ADC_CALIBRATE",
      "enabled": true,
      "value": "",
      "description": "Enable ADC Calibrate"
    },
    {
      "macro": "PWM_MODULATOR_USING_NEGATIVE_LOGIC",
      "enabled": true,
      "value": "1",
      "description": "Using negative modulator logic"
    },
    {
      "macro": "USING_NPC_MODULATOR",
      "enabled": false,
      "value": "",
      "description": "Using three level modulator or two level modulator"
    }
  ],
  "option_macros": [
    {
      "macro": "BUILD_LEVEL",
      "enabled": true,
      "value": "1",
      "options_preset": "",
      "options": [
        "1",
        "2",
        "3",
        "4",
        "5"
      ],
      "description": ""
    }
  ],
  "requirement_groups": [
    {
      "name": "Requirements",
      "requirements": [
        "input_voltage_sensor_sensitivity",
        "input_voltage_sensor_bias",
        "inductor_current_sensitivity",
        "inductor_current_bias",
        "output_voltage_sensor_sensitivity",
        "output_voltage_sensor_bias",
        "tmcs1133_b2a_range_for_reference",
        "manual_input_voltage_adc_offset"
      ]
    }
  ]
}
