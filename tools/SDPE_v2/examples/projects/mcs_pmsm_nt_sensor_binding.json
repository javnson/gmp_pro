{
  "id": "mcs_pmsm_nt_sensor_IRIS_node",
  "display_name": "MCS PMSM NT F280049C Binding Example",
  "description": "Typical PMSM_NT ctrl_settings-style requirement list for controller base values, motor parameters, sensor scaling, debug switches, and board peripheral aliases.\nMultiline comments here.",
  "suite": "mcs_pmsm_nt",
  "version": "0.2.0",
  "updated_at": "2026-07-10",
  "output_header": "sdpe_mcs_pmsm_nt_bindings.h",
  "hardware": [
    {
      "entity": "sm060r20b30mnad"
    },
    {
      "entity": "gmp_lvfb_150_2ph_v2"
    }
