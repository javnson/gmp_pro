      ],
      "description": ""
    },
    {
      "macro": "PWM_PHASE_V",
      "enabled": true,
      "value": "IRIS_EPWM2_BASE",
      "options_preset": "IRIS_EPWM",
      "options": [
        "IRIS_EPWM1_BASE",
        "IRIS_EPWM2_BASE",
        "IRIS_EPWM3_BASE",
        "IRIS_EPWM4_BASE",
        "IRIS_EPWM5_BASE",
