        "IRIS_EPWM2_BASE",
        "IRIS_EPWM3_BASE",
        "IRIS_EPWM4_BASE",
        "IRIS_EPWM5_BASE",
        "IRIS_EPWM6_BASE"
      ],
      "description": ""
    }
  ],
  "requirements": [
    {
      "role": "startup_delay",
      "macro": "CTRL_STARTUP_DELAY",
      "binding": {
        "number": "100"
      },
      "description": "Startup delay in ms."
    },
    {
      "role": "controller_frequency",
      "macro": "CONTROLLER_FREQUENCY",
      "binding": {
        "number": "20e3"
      },
      "description": "Controller ISR frequency."
    },
    {
      "role": "pwm_cmp_max",
      "macro": "CTRL_PWM_CMP_MAX",
      "binding": {
        "number": "2500 - 1"
      },
      "description": "PWM compare maximum."
    },
    {
      "role": "pwm_deadband",
      "macro": "CTRL_PWM_DEADBAND_CMP",
      "binding": {
        "number": "100"
      },
      "description": "PWM dead band compare value."
    },
    {
      "role": "adc_voltage_reference",
      "macro": "CTRL_ADC_VOLTAGE_REF",
      "binding": {
        "float": "3.3"
      },
      "description": "ADC voltage reference."
    },
    {
      "role": "mechanical_division",
      "macro": "CTRL_MECH_DIV",
      "binding": {
        "literal": "5"
      },
      "description": "Speed and position mechanical division."
    },
    {
      "role": "dc_bus_voltage",
      "macro": "CTRL_DCBUS_VOLTAGE",
      "binding": {
        "float": "80.0"
      },
      "description": "DC bus base voltage."
    },
    {
      "role": "phase_voltage_base",
      "macro": "CTRL_VOLTAGE_BASE",
      "binding": {
        "literal": "(CTRL_DCBUS_VOLTAGE / 1.73205081f)"
      },
      "description": "Phase voltage base for SVPWM modulation."
    },
    {
      "role": "current_base",
      "macro": "CTRL_CURRENT_BASE",
      "binding": {
        "float": "10.0"
      },
      "description": "Current base value."
    },
    {
      "role": "inverter_current_sensitivity",
      "macro": "CTRL_INVERTER_CURRENT_SENSITIVITY",
      "binding": {
        "expr": "${gmp_lvfb_150_2ph_v2.current_sensitivity}/2"
      },
      "description": "Inverter side current sensor sensitivity."
    },
    {
      "role": "inverter_current_bias",
      "macro": "CTRL_INVERTER_CURRENT_BIAS",
      "binding": {
        "export": "${gmp_lvfb_150_2ph_v2.voltage_sensor.bias}"
      },
      "description": "Inverter side current sensor bias."
    },
    {
      "role": "inverter_voltage_sensitivity",
      "macro": "CTRL_INVERTER_VOLTAGE_SENSITIVITY",
      "binding": {
        "export": "${gmp_lvfb_150_2ph_v2.voltage_sensitivity}"
      },
      "description": "Inverter side voltage sensor sensitivity."
    },
    {
      "role": "inverter_voltage_bias",
      "macro": "CTRL_INVERTER_VOLTAGE_BIAS",
      "binding": {
        "export": "${gmp_lvfb_150_2ph_v2.voltage_sensor.bias_v}"
      },
      "description": "Inverter side voltage sensor bias."
    },
    {
      "role": "motor_rs",
      "macro": "CTRL_MOTOR_RS",
      "binding": {
        "export": "${sm060r20b30mnad.rs}"
      },
      "description": "Selected PMSM stator resistance."
    },
    {
      "role": "motor_ld",
      "macro": "CTRL_MOTOR_LD",
      "binding": {
        "export": "${sm060r20b30mnad.ld}"
      },
      "description": "Selected PMSM d-axis inductance."
    },
    {
      "role": "motor_lq",
      "macro": "CTRL_MOTOR_LQ",
      "binding": {
        "export": "${sm060r20b30mnad.lq}"
      },
      "description": "Selected PMSM q-axis inductance."
    },
    {
      "role": "encoder_bias",
      "macro": "CTRL_POS_ENC_BIAS",
      "binding": {
        "float": "0.0207000002"
      },
      "description": "Encoder mechanical bias."
    }
  ],
  "peripheral_bindings": {
