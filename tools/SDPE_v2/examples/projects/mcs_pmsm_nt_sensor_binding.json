  "option_macros": [
    {
      "macro": "BUILD_LEVEL",
      "enabled": true,
      "value": "(4)",
      "options_preset": "",
      "options": [
        "(1)",
        "(2)",
        "(3)",
        "(4)",
        "(5)",
        "(6)"
      ],
      "description": "PMSM_NT incremental debug build level.\nBUILD_LEVEL 1: hardware validate, VF, voltage open loop\nBUILD_LEVEL 2: IF, current close loop\nBUILD_LEVEL 3: current loop with actual angle\nBUILD_LEVEL 4: speed loop\nBUILD_LEVEL 5: position loop\nBUILD_LEVEL 6: communication mode"
    },
    {
      "macro": "MC_CURRENT_SAMPLE_PHASE_MODE",
      "enabled": true,
      "value": "(2)",
      "options_preset": "",
      "options": [
        "(1)",
        "(2)",
        "(3)"
      ],
      "description": "Motor current sample phase mode."
    },
    {
      "macro": "PWM_ENABLE_PORT",
      "enabled": true,
      "value": "IRIS_GPIO1",
      "options_preset": "IRIS_GPIO",
      "options": [
        "IRIS_GPIO1",
        "IRIS_GPIO2",
        "IRIS_GPIO3",
        "IRIS_GPIO4",
        "IRIS_GPIO5",
        "IRIS_GPIO6"
      ],
      "description": ""
    },
    {
      "macro": "PWM_RESET_PORT",
      "enabled": true,
      "value": "IRIS_GPIO3",
      "options_preset": "IRIS_GPIO",
      "options": [
        "IRIS_GPIO1",
        "IRIS_GPIO2",
        "IRIS_GPIO3",
        "IRIS_GPIO4",
        "IRIS_GPIO5",
        "IRIS_GPIO6"
      ],
      "description": ""
    },
    {
      "macro": "PWM_PHASE_U",
      "enabled": true,
      "value": "IRIS_EPWM1_BASE",
      "options_preset": "IRIS_EPWM",
      "options": [
        "IRIS_EPWM1_BASE",
        "IRIS_EPWM2_BASE",
        "IRIS_EPWM3_BASE",
        "IRIS_EPWM4_BASE",
        "IRIS_EPWM5_BASE",
